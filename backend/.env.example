NODE_ENV=development
PORT=3001

# Mock mode — no real credentials needed
SALESFORCE_MODE=mock
STRIPE_MODE=mock

# Real Salesforce (only when SALESFORCE_MODE=live)
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_REDIRECT_URI=http://localhost:3001/auth/callback

# Real Stripe (only when STRIPE_MODE=live)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# JWT secret for session tokens
JWT_SECRET=fieldpay-dev-secret-change-in-production
